{
  "name": "gyfchong-portfolio",
  "description": "Geoffrey Chong's portfolio",
  "author": {
    "name": "Geoffrey Chong",
    "url": "http://geoffreychong.com"
  },
  "license": "MIT",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/gyfchong/portfolio"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "npx @11ty/eleventy --serve --quiet",
    "build": "rimraf _site && npx @11ty/eleventy",
    "debug": "DEBUG=Eleventy* npx @11ty/eleventy",
    "debugstart": "DEBUG=Eleventy* npx @11ty/eleventy --serve --quiet",
    "deploy": "pnpm run build && wrangler deploy",
    "preview": "pnpm run build && wrangler dev"
  },
  "dependencies": {
    "normalize.css": "^8.0.1",
    "reset.css": "^2.0.2"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-dev-server": "^2.0.8",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-bundle": "^3.0.7",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cssnano": "^7.1.4",
    "eleventy-plugin-postcss": "^3.0.1",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^14.0.0",
    "rimraf": "^6.1.3",
    "svgo": "^4.0.1",
    "wrangler": "^4.80.0"
  }
}
